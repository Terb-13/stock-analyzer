# =============================================================================
# LOCAL: copy to `.streamlit/secrets.toml` (gitignored).
# STREAMLIT COMMUNITY CLOUD: paste this entire file into **App settings → Secrets**
# (same TOML format). Do not commit real secrets to Git.
# =============================================================================

# --- Optional: API keys (same names as .env — Cloud has no .env file) ----------
# FMP_API_KEY = ""
# SEC_API_KEY = ""
# XAI_API_KEY = ""
# UNUSUAL_WHALES_API_KEY = ""
# POLYGON_API_KEY = ""
# SEC_EDGAR_USER_AGENT = "MillenniallityScanner your.email@domain.com"

# --- Admin --------------------------------------------------------------------
# In-app admin (User Management expander) is fixed to username **terb13** in code.

# --- streamlit-authenticator (bcrypt password hash required) -------------------
# Generate a hash (use the same Python env as the app):
#   from streamlit_authenticator.utilities.hasher import Hasher
#   print(Hasher.hash_list(["your-long-password"])[0])
#
# Example hash is for password **TempPass12345!** — replace in production.
[credentials.usernames.terb13]
email = "owner@example.com"
name = "terb13"
password = "$2b$12$C9s6QPCqACeSww4feYCIO.EKvmlYbH7jWT8aWOjHcn3JcC/lWNO72"

[cookie]
name = "millenniallity_auth_cookie"
key = "REPLACE_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS"
expiry_days = 30
