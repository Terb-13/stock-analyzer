# Copy to `.env` in this folder, fill in values, and never commit `.env`.
# LLM narrative uses xAI only (XAI_API_KEY).

# Invite-only login (Supabase). See schema_auth.sql — use service_role key server-side only.
# Must be true or the app skips login entirely (even if Supabase is set up):
# REQUIRE_LOGIN=true
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# First approved user (created automatically if missing). Password ≥ 10 chars.
# ADMIN_EMAIL=you@yourdomain.com
# ADMIN_PASSWORD=
# Sidebar “approve users” passphrase (`APP_ADMIN_SECRET` or `app_admin_secret`):
# APP_ADMIN_SECRET=long-random-string

FMP_API_KEY=
# sec.gov: set a real contact email in the User-Agent (10-K URL fallback when FMP limits out)
SEC_EDGAR_USER_AGENT=MillenniallityScanner your.email@domain.com
SEC_API_KEY=
POLYGON_API_KEY=
UNUSUAL_WHALES_API_KEY=
XAI_API_KEY=
# Default in code: grok-4.20-0309-reasoning — override if your tier differs (console.x.ai).
# XAI_MODEL=grok-4.20-0309-reasoning
